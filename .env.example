# Optional: use a separate signaling WebSocket service instead of the
# same-origin Nuxt route. Examples:
# VITE_SIGNALING_URL=wss://signal.example.com

# Optional but recommended for reliable WebRTC across restrictive NATs,
# corporate networks, and mobile carriers. These values are compiled into
# the browser bundle and are therefore public. Use restricted/short-lived
# TURN credentials from your provider, never a private provider API key.
# VITE_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# VITE_TURN_USERNAME=temporary-username
# VITE_TURN_CREDENTIAL=temporary-password
